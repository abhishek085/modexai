# ModexAI Environment Variables
# Copy to .env and fill in real values before running.

# ── Stripe ─────────────────────────────────────────────────────────────────
# Use "mock" locally; replace with your Stripe secret key for production.
STRIPE_MOCK_KEY=mock

# ── Ollama ─────────────────────────────────────────────────────────────────
# Default host when running via Docker Compose (service name = "ollama").
# Change to http://localhost:11434 when running the API outside of Compose.
OLLAMA_HOST=http://ollama:11434

# ── API ────────────────────────────────────────────────────────────────────
# Internal port exposed by the FastAPI container.
API_PORT=8000
